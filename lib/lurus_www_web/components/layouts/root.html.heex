<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content={get_csrf_token()} />
  <meta name="description" content={assigns[:page_description] || "WebGame - AI-Powered Game Creation Platform"} />
  <meta name="keywords" content="WebGame, AI Games, Multiplayer Snake, Game Creator, Real-time Games" />

  <.live_title default="WebGame" suffix="">
    {assigns[:page_title] || "WebGame"}
  </.live_title>

  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
  <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
</head>
<body>
  {@inner_content}
</body>
</html>
